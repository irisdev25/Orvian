{
  "version": 2,
  "builds": [
    {
      "src": "Backend/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "Frontend/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "Frontend/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "Frontend/public/js/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "Frontend/public/img/favicon.png"
    },
    {
      "src": "/favicon.ico",
      "dest": "Frontend/public/img/favicon.png"
    },
    {
      "src": "/img/(.*)",
      "dest": "Frontend/public/img/$1"
    },
    {
      "src": "/(.*)",
      "dest": "Backend/app.js"
    }
  ]
}
