{
  "version": 2,
  "builds": [
    {
      "src": "Backend/app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "Frontend/views/**",
          "public/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Backend/app.js"
    }
  ]
}
