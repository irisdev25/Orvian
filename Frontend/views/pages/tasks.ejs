<link rel="stylesheet" href="/css/tasks.css">

<div class="tasks-header">
    <div class="header-left">
        <h1>Mis Tareas</h1>
        <p class="text-secondary">Gestiona tus actividades y objetivos.</p>
    </div>
    <div class="header-right" style="display: flex; gap: 10px;">
        <button class="btn btn-secondary" id="btnExportTasks">
            <i class="fas fa-file-export"></i> Exportar
        </button>
        <button class="btn btn-primary" id="btnNewTask">
            <i class="fas fa-plus"></i> Nueva Tarea
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="card filters-card" style="margin-bottom: 25px; padding: 15px;">
    <form action="/tasks" method="GET" style="display: flex; gap: 15px; align-items: center;">
        <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" id="taskSearch" name="search" placeholder="Buscar tareas..." value="<%= filters.search || '' %>">
        </div>
        <select name="status" onchange="this.form.submit()" class="filter-select">
            <option value="">Todos los estados</option>
            <option value="Pendiente" <%= filters.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
            <option value="En progreso" <%= filters.status === 'En progreso' ? 'selected' : '' %>>En progreso</option>
            <option value="Completada" <%= filters.status === 'Completada' ? 'selected' : '' %>>Completada</option>
            <option value="Cancelada" <%= filters.status === 'Cancelada' ? 'selected' : '' %>>Cancelada</option>
        </select>
        <button type="submit" class="btn btn-primary">Filtrar</button>
    </form>
</div>

<div class="tasks-list">
    <% if (tasks.length === 0) { %>
        <div class="card empty-card">
            <i class="fas fa-tasks"></i>
            <p>No se encontraron tareas. ¡Crea una nueva para empezar!</p>
        </div>
    <% } else { %>
        <% tasks.forEach(tarea => { %>
            <div class="card task-card" style="--border-cat: <%= tarea.category_color || 'var(--color-main)' %>">
                <div class="task-info">
                    <div class="task-top-meta">
                        <span class="badge badge-priority <%= tarea.priority.toLowerCase() %>"><%= tarea.priority %></span>
                        <% if (tarea.category_name) { %>
                            <span class="cat-tag" style="--tag-color: <%= tarea.category_color %>">
                                <i class="fas fa-tag"></i> <%= tarea.category_name %>
                            </span>
                        <% } %>
                    </div>
                    <h3><%= tarea.title %></h3>
                    <p class="text-secondary"><%= tarea.description || 'Sin descripción' %></p>
                    
                        <div class="task-meta">
                            <% if (tarea.due_date) { %>
                                <span><i class="far fa-calendar"></i> <%= new Date(tarea.due_date).toLocaleDateString() %></span>
                            <% } %>
                            <% if (tarea.subtask_total > 0) { %>
                                <span style="margin-left: 15px; color: var(--color-main); font-weight: 700;">
                                    <i class="fas fa-list-check"></i> <%= tarea.subtask_completed %>/<%= tarea.subtask_total %> 
                                </span>
                            <% } %>
                        </div>
                </div>
                
                <div class="task-actions">
                    <select class="status-select task-status-update <%= (tarea.status || 'Pendiente').toLowerCase().replace(' ', '-') %>" data-id="<%= tarea.id %>">
                        <option value="Pendiente" <%= tarea.status === 'Pendiente' ? 'selected' : '' %>>Pendiente</option>
                        <option value="En progreso" <%= tarea.status === 'En progreso' ? 'selected' : '' %>>En progreso</option>
                        <option value="Completada" <%= tarea.status === 'Completada' ? 'selected' : '' %>>Completada</option>
                        <option value="Cancelada" <%= tarea.status === 'Cancelada' ? 'selected' : '' %>>Cancelada</option>
                    </select>
                    <div class="action-buttons">
                        <button class="btn-icon btn-edit-task" 
                                data-id="<%= tarea.id %>" 
                                data-title="<%= tarea.title %>"
                                data-desc="<%= tarea.description %>"
                                data-priority="<%= tarea.priority %>"
                                data-date="<%= tarea.due_date ? new Date(tarea.due_date).toISOString().split('T')[0] : '' %>"
                                data-cat="<%= tarea.category_id %>"
                                title="Editar">
                            <i class="fas fa-edit"></i>
                        </button>
                        <a href="/tasks/delete/<%= tarea.id %>" class="btn-icon" onclick="return confirm('¿Seguro que quieres eliminar esta tarea?')" title="Eliminar">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<!-- Modal Nueva/Editar Tarea -->
<div id="taskModal" class="modal">
    <div class="modal-content">
        <span class="close">&times;</span>
        <h2 id="modalTitle">Nueva Tarea</h2>
        <form id="taskForm" action="/tasks" method="POST" class="modal-form">
            <div class="form-group">
                <label for="title">Título de la Tarea</label>
                <input type="text" id="title" name="title" required placeholder="¿Qué hay que hacer?">
            </div>
            <div class="form-group">
                <label for="description">Descripción</label>
                <textarea id="description" name="description" placeholder="Añade más detalles..." rows="3"></textarea>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label for="priority">Prioridad</label>
                    <select id="priority" name="priority">
                        <option value="Baja">Baja</option>
                        <option value="Media" selected>Media</option>
                        <option value="Alta">Alta</option>
                        <option value="Urgente">Urgente</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="due_date">Fecha de Vencimiento</label>
                    <input type="date" id="due_date" name="due_date">
                </div>
            </div>
            <div class="form-group">
                <label for="category_id">Categoría</label>
                <select id="category_id" name="category_id">
                    <option value="">Sin Categoría</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat.id %>"><%= cat.name %></option>
                    <% }) %>
                </select>
            </div>
            
            <!-- Sección de Subtareas (Solo aparece al editar) -->
            <div id="subtasksSection" style="margin-top: 20px; display: none;">
                <h4 style="margin-bottom: 10px; border-top: 1px solid var(--border-color); padding-top: 15px;">Checklist de Subtareas</h4>
                <div id="subtaskList" style="margin-bottom: 10px;"></div>
                <div style="display: flex; gap: 10px;">
                    <input type="text" id="newSubtaskTitle" placeholder="Añadir paso..." style="flex-grow: 1; padding: 8px;">
                    <button type="button" class="btn btn-primary" id="btnAddSubtask" style="padding: 5px 15px;">+</button>
                </div>
            </div>

            <div class="form-submit">
                <button type="submit" class="btn btn-primary" id="btnSubmit">Crear Tarea</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/tasks.js"></script>
