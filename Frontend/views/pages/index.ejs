<div id="statsData" data-stats="<%= JSON.stringify(stats) %>" style="display: none;"></div>

<div class="dashboard-overview">
    <div class="welcome-section" style="margin-bottom: 35px;">
        <h1>Resumen Diario</h1>
        <p class="text-secondary">Aquí tienes un vistazo de tu productividad de hoy.</p>
    </div>

    <!-- Tarjetas de Estadísticas -->
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px; margin-bottom: 40px;">
        
        <div class="card stat-card" style="border-bottom: 3px solid var(--color-main);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p class="text-secondary" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Total de Tareas</p>
                    <h2 style="font-size: 2.2rem; margin-top: 5px;"><%= stats.total || 0 %></h2>
                </div>
                <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: var(--color-main); width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="fas fa-list-check"></i>
                </div>
            </div>
        </div>

        <div class="card stat-card" style="border-bottom: 3px solid var(--color-success);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p class="text-secondary" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Completadas</p>
                    <h2 style="font-size: 2.2rem; margin-top: 5px;"><%= stats.completed || 0 %></h2>
                </div>
                <div class="stat-icon" style="background: rgba(34, 197, 94, 0.1); color: var(--color-success); width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="fas fa-circle-check"></i>
                </div>
            </div>
        </div>

        <div class="card stat-card" style="border-bottom: 3px solid #f59e0b;">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p class="text-secondary" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Pendientes</p>
                    <h2 style="font-size: 2.2rem; margin-top: 5px;"><%= stats.pending || 0 %></h2>
                </div>
                <div class="stat-icon" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="fas fa-clock"></i>
                </div>
            </div>
        </div>

        <div class="card stat-card" style="border-bottom: 3px solid var(--color-error);">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <p class="text-secondary" style="font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Vencidas</p>
                    <h2 style="font-size: 2.2rem; margin-top: 5px;"><%= stats.overdue || 0 %></h2>
                </div>
                <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: var(--color-error); width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="fas fa-triangle-exclamation"></i>
                </div>
            </div>
        </div>

    </div>

    <!-- Gráficos -->
    <div class="charts-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 30px;">
        <div class="card chart-card" style="min-height: 450px; display: flex; flex-direction: column;">
            <h3 style="margin-bottom: 25px;">Distribución por Estado</h3>
            <div style="flex-grow: 1; position: relative; width: 100%;">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
        <div class="card chart-card" style="min-height: 450px; display: flex; flex-direction: column;">
            <h3 style="margin-bottom: 25px;">Tareas por Prioridad</h3>
            <div style="flex-grow: 1; position: relative; width: 100%;">
                <canvas id="priorityChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="/js/dashboard.js"></script>
